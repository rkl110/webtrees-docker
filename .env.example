# ==============================================================================
# webtrees deployment configuration
#
# Copy this file to `.env` and adjust the values:
#   cp .env.example .env
#
# The `.env` file is read automatically by `podman compose` / `docker compose`.
# It contains secrets - never commit it (it is gitignored).
#
# Note: quote values that contain spaces or special characters,
# e.g. WT_NAME="Full Name"
# ==============================================================================

# ------------------------------------------------------------------------------
# Images / versions
#
# The webtrees image is built locally from this repository (docker/Dockerfile).
# To upgrade webtrees, change WEBTREES_VERSION and run `./scripts/upgrade.sh`,
# or directly run `./scripts/upgrade.sh <version>`.
# Available versions: https://github.com/fisharebest/webtrees/releases
# ------------------------------------------------------------------------------
WEBTREES_IMAGE=localhost/webtrees
WEBTREES_VERSION=2.2.6

# Build arguments. For the PHP and upgrade-patch version matching a
# webtrees release, see dev/versions.json (upstream builds 2.2.x with
# php 8.4 / patch 2; 8.5 works as well).
PHP_VERSION=8.5
UPGRADE_PATCH_VERSION=2

MARIADB_IMAGE=docker.io/library/mariadb
# See: https://github.com/NathanVaughn/webtrees-docker/issues/145
MARIADB_VERSION=12

# ------------------------------------------------------------------------------
# Network
#
# Unprivileged ports (>1024) so the containers can run rootless.
# ------------------------------------------------------------------------------
HTTP_PORT=8080
HTTPS_PORT=8443

# Base URL of the installation, with protocol and port.
# IMPORTANT: this must be the URL you actually type into the browser
# (e.g. http://192.168.1.50:8080 or http://server.example.com:8080).
# webtrees redirects to this URL - if it says "localhost" but you access
# the server remotely, the browser will be redirected into nowhere.
# Behind a reverse proxy, use the public URL instead.
BASE_URL=http://localhost:8080

# ------------------------------------------------------------------------------
# Reverse proxy (optional), see https://webtrees.net/admin/proxy/
#
# When webtrees runs behind a reverse proxy:
#   - set BASE_URL to the public URL (e.g. https://family.example.com)
#   - keep HTTPS=0 (TLS terminates at the proxy)
#   - set TRUSTED_PROXIES so webtrees sees real client IPs: comma-separated
#     IPs or CIDR ranges of the proxy as seen by the container. With
#     rootless Podman this is the internal gateway address, check the
#     first "client IP" shown in Control panel -> Server information.
#   - if the proxy sends the client IP in a special header, set
#     TRUSTED_HEADERS (e.g. cf-connecting-ip for Cloudflare)
#   - with a proxy on the same host, set BIND_ADDRESS=127.0.0.1 so the
#     app ports are not reachable from outside directly. IMPORTANT: only
#     trust proxies if direct access is blocked - otherwise anyone can
#     spoof their IP via the X-Forwarded-For header.
# ------------------------------------------------------------------------------
#TRUSTED_PROXIES=10.0.2.0/24
#TRUSTED_HEADERS=
#BIND_ADDRESS=127.0.0.1

# ------------------------------------------------------------------------------
# webtrees settings
# ------------------------------------------------------------------------------
# Enable pretty URLs (https://webtrees.net/faq/urls/)
PRETTY_URLS=1

# HTTPS directly in the container. Certificates are read from ./certs/
# (mounted to /certs/). Generate self-signed ones with `make certs`,
# then set HTTPS=1 and use BASE_URL=https://<host>:8443.
# HTTPS_REDIRECT=1 additionally forces a permanent redirect to HTTPS.
# Usually left off when running behind a reverse proxy.
HTTPS=0
HTTPS_REDIRECT=0
SSL_CERT_FILE=/certs/webtrees.crt
SSL_CERT_KEY_FILE=/certs/webtrees.key

# webtrees-Sprachcode, z.B. de, en-US, fr (muss ein Ordner in der Liste sein;
# "de-DE" ist UNGUELTIG und fuehrt beim ersten Login zu einem I18N-Fehler)
# List: https://github.com/fisharebest/webtrees/tree/main/resources/lang/
WEBTREES_LANG=de

# ------------------------------------------------------------------------------
# Database (MariaDB container "db")
#
# CHANGE BOTH PASSWORDS before the first start!
# e.g. generate with: openssl rand -base64 24
# ------------------------------------------------------------------------------
DB_NAME=webtrees
DB_USER=webtrees
DB_PASS=CHANGE_ME_db_password
DB_PREFIX=wt_

MARIADB_ROOT_PASSWORD=CHANGE_ME_root_password

# ------------------------------------------------------------------------------
# First admin account
#
# Only used on the very first start to initialize webtrees.
# All four values must be set for the automatic setup.
# ------------------------------------------------------------------------------
WT_USER=admin
WT_NAME="Admin User"
WT_PASS=CHANGE_ME_admin_password
WT_EMAIL=admin@example.com

# ------------------------------------------------------------------------------
# PHP tuning (optional)
# ------------------------------------------------------------------------------
PHP_MEMORY_LIMIT=1024M
PHP_MAX_EXECUTION_TIME=90
PHP_POST_MAX_SIZE=50M
PHP_UPLOAD_MAX_FILE_SIZE=50M

# Note: the containers run entirely without root. The app runs as
# www-data (33), the database as mysql (999); with rootless Podman both
# are mapped into the user namespace of your host user.
